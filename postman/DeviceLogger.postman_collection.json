      "value": "station-01",
      "type": "string"
    },
    {
      "key": "traceId",
      "value": "job-REPLACE-ME",
      "type": "string"
    },
    {
      "key": "licenseToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "protoFile",
      "value": "api/proto/devicelog/v1/query.proto",
      "type": "string"
    },
    {
      "key": "protoImportPath",
      "value": "api/proto",
      "type": "string"
    }
  ]
}
