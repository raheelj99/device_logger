{
  "name": "devlog-nest-client",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS client for devlogd: REST facade + CLI over MQTT/TLS ingest + gRPC/TLS observation",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "e2e": "ts-node src/e2e.ts",
    "test": "jest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "mqtt": "^5.5.0",
    "protobufjs": "^7.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
